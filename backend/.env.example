# Backend Environment Variables

# Database Connection String
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/marketplace_db

# Secret key for JWT signing - must be strong and unique in production
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production

# JWT Algorithm (e.g., HS256)
JWT_ALGORITHM=HS256

# JWT token expiration time in minutes
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Base directory for saving uploaded files
UPLOAD_DIR=uploads

# Maximum allowed size for an image upload (MB)
MAX_IMAGE_SIZE_MB=10

# Maximum allowed size for a message attachment (MB)
MAX_ATTACHMENT_SIZE_MB=5

# Maximum number of images allowed per listing
MAX_IMAGES_PER_LISTING=5

# Comma-separated list of allowed image MIME types
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# Comma-separated list of allowed attachment MIME types
ALLOWED_ATTACHMENT_TYPES=image/jpeg,image/png,image/webp,application/pdf

# Default admin email
ADMIN_EMAIL=admin@marketplace.com

# Default admin password
ADMIN_PASSWORD=admin123
